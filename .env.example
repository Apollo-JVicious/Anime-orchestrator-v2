# Local development defaults. Copy this file to .env and provide secrets there.
# Never commit real credentials.

NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
MCP_ALLOWED_HOSTS=localhost,127.0.0.1
TRUST_PROXY_HOPS=0

# Required for live Gemini-backed features. Keep server-side only.
GEMINI_API_KEY=

# Local/single-instance integrations database. Use durable shared storage in production.
INTEGRATIONS_DB_PATH=./data/integrations.sqlite

# Generate separate high-entropy values for these two secrets.
# Do not reuse an MCP integration bearer token for either setting.
INTEGRATION_TOKEN_PEPPER=
INTEGRATIONS_ADMIN_TOKEN=

# Protect existing REST mutation routes in deployed environments.
REQUIRE_LEGACY_WRITE_AUTH=true
REQUIRE_LEGACY_READ_AUTH=true
# Development-only escape hatch. When true, the server binds insecure access to loopback by default.
ALLOW_INSECURE_LOCAL_API=false

# Request limits per server-configured limiter window.
MCP_AUTH_FAILURE_LIMIT=10
MCP_GENERATION_RATE_LIMIT=5

# Trusted price in micro-dollars per second for provider:model:resolution.
# Example only: {"provider:model:1920x1080":250000}
GENERATION_PRICING_JSON={}

# Development-only legacy UI simulation. Never enable in production.
ALLOW_SIMULATED_GENERATION=false
